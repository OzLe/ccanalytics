{
  "name": "ccanalytics",
  "version": "0.1.5",
  "description": "Local-first analytics for Claude Code sessions — cost tracking, cache efficiency, tool usage patterns",
  "type": "module",
  "bin": {
    "ccanalytics": "./dist/cli.cjs"
  },
  "main": "./dist/cli.cjs",
  "files": [
    "dist",
    "sql",
    "dashboard"
  ],
  "scripts": {
    "build": "bash scripts/update-version.sh && tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "build:dashboard": "cd dashboard && npm run build",
    "backfill:costs": "dashboard/node_modules/.bin/tsx scripts/backfill-costs.ts",
    "backfill:loaded-skills": "dashboard/node_modules/.bin/tsx scripts/backfill-loaded-skills.ts",
    "prepublishOnly": "npm run build",
    "version:update": "bash scripts/update-version.sh"
  },
  "dependencies": {
    "@duckdb/node-api": "1.4.4-r.1",
    "chokidar": "^5",
    "cli-table3": "^0.6",
    "commander": "^12",
    "nanospinner": "^1",
    "picocolors": "^1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22",
    "@vitest/coverage-v8": "^3.2.4",
    "express": "^4.21.0",
    "tsup": "^8",
    "typescript": "^5.7",
    "vitest": "^3"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "claude",
    "claude-code",
    "analytics",
    "duckdb",
    "cli",
    "cost-tracking"
  ],
  "license": "MIT",
  "author": "Oz Levi (https://github.com/OzLe)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OzLe/ccanalytics.git"
  },
  "bugs": {
    "url": "https://github.com/OzLe/ccanalytics/issues"
  },
  "homepage": "https://github.com/OzLe/ccanalytics#readme"
}
